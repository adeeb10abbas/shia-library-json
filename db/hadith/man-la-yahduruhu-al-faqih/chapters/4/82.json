      "translations": {
        "en.bab-ul-qaim-publications": {
          "segments": [
            "Hadith.5418 - Abdullah ibn Al-Mughirah narrated from Al-Sakuni from Imam Jafar ibn Muhammad Al-Sadiq (as) from his father, Imam Muhammad ibn Ali Al-Baqir (as), that Imam Ali ibn Abi Talib (as) said:\n\"I do not mind whether I cause hardship to my children or I spend that wealth on them.\""
          ],
          "text": "Hadith.5418 - Abdullah ibn Al-Mughirah narrated from Al-Sakuni from Imam Jafar ibn Muhammad Al-Sadiq (as) from his father, Imam Muhammad ibn Ali Al-Baqir (as), that Imam Ali ibn Abi Talib (as) said:\n\"I do not mind whether I cause hardship to my children or I spend that wealth on them.\""
        }
