      "translations": {
        "en.bab-ul-qaim-publications": {
          "segments": [
            "Hadith.5414 - Al-Sakuni narrated from Imam Jafar ibn Muhammad Al-Sadiq (as) from his father, Imam Muhammad ibn Ali Al-Baqir (as), that Imam Ali ibn Abi Talib (as) said:\n\"Whoever makes a will without being excessive or causing harm, it is as if he gave it in charity during his lifetime.\""
          ],
