      "translations": {
        "en.bab-ul-qaim-publications": {
          "segments": [
            "Hadith.5327 - Al-Hasan ibn Mahbub narrated from Al-Harith ibn Muhammad from Zayd from Abu Jafar Imam Muhammad ibn Ali Al-Baqir (as) regarding a man who had intercourse with his wife in her rear and persisted until she died from it.\nImam (as) said: \"He must pay the full blood money (diyyah).\""
          ],
          "text": "Hadith.5327 - Al-Hasan ibn Mahbub narrated from Al-Harith ibn Muhammad from Zayd from Abu Jafar Imam Muhammad ibn Ali Al-Baqir (as) regarding a man who had intercourse with his wife in her rear and persisted until she died from it.\nImam (as) said: \"He must pay the full blood money (diyyah).\""
        }
