      "arabic": {
        "segments": [
          " سَأَلْتُهُ عَنْ رَجُلٍ افْتَرَى عَلَى قَوْمٍ جَمَاعَةً قَالَ إِنْ أَتَوْا بِهِ مُجْتَمِعِينَ ضُرِبَ حَدّاً وَاحِداً وَ إِنْ أَتَوْا بِهِ مُتَفَرِّقِينَ ضُرِبَ لِكُلِّ وَاحِدٍ مِنْهُمْ حَدّاً ."
        ],
        "text": "سَأَلْتُهُ عَنْ رَجُلٍ افْتَرَى عَلَى قَوْمٍ جَمَاعَةً قَالَ إِنْ أَتَوْا بِهِ مُجْتَمِعِينَ ضُرِبَ حَدّاً وَاحِداً وَ إِنْ أَتَوْا بِهِ مُتَفَرِّقِينَ ضُرِبَ لِكُلِّ وَاحِدٍ مِنْهُمْ حَدّاً ."
      },
      "translations": {
        "en.hubeali": {
          "segments": [
            "Ali Bin Ibrahim, from his father, from Ibn Abu Umeyr, from Jameel Bin Darraj, ",
            "(It has been narrated) from Abu Abdullah<sup>asws</sup>, said, ‘I asked him<sup>asws</sup> about a man who fabricated upon a group of people. He<sup>asws</sup> said: ‘If they come with it altogether, he would be whipped with one Penalty (<span class=\"iTxt\">Hadd</span>), and if they come to be separately, he would be whipped a Penalty (<span class=\"iTxt\">Hadd</span>) for each one of them’."
          ],
          "text": "Ali Bin Ibrahim, from his father, from Ibn Abu Umeyr, from Jameel Bin Darraj,\n\n(It has been narrated) from Abu Abdullah<sup>asws</sup>, said, ‘I asked him<sup>asws</sup> about a man who fabricated upon a group of people. He<sup>asws</sup> said: ‘If they come with it altogether, he would be whipped with one Penalty (<span class=\"iTxt\">Hadd</span>), and if they come to be separately, he would be whipped a Penalty (<span class=\"iTxt\">Hadd</span>) for each one of them’."
        }
      },
