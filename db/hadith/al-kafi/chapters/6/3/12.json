      "arabic": {
        "segments": [
          " قَالَ رَسُولُ اللَّهِ ( صلى الله عليه وآله ) إِذَا عَمِيَ الْمَمْلُوكُ فَلَا رِقَّ عَلَيْهِ وَ الْعَبْدُ إِذَا جُذِمَ فَلَا رِقَّ عَلَيْهِ ."
        ],
        "text": "قَالَ رَسُولُ اللَّهِ ( صلى الله عليه وآله ) إِذَا عَمِيَ الْمَمْلُوكُ فَلَا رِقَّ عَلَيْهِ وَ الْعَبْدُ إِذَا جُذِمَ فَلَا رِقَّ عَلَيْهِ ."
      },
      "translations": {
        "en.hubeali": {
          "segments": [
            "Ali Bin Ibrahim, from his father, from Al Nowfaly, from Al Sakuny, ",
            "(It has been narrated) from Abu Abdullah<sup>asws</sup> having said: ‘Rasool-Allah<sup>saww</sup> said: ‘When the owned slave is blinded, so there is no slavery upon him; and the slave, when he is suffers from leprosy, so there is no slavery upon him’."
          ],
          "text": "Ali Bin Ibrahim, from his father, from Al Nowfaly, from Al Sakuny,\n\n(It has been narrated) from Abu Abdullah<sup>asws</sup> having said: ‘Rasool-Allah<sup>saww</sup> said: ‘When the owned slave is blinded, so there is no slavery upon him; and the slave, when he is suffers from leprosy, so there is no slavery upon him’."
        }
